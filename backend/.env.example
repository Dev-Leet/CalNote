# Server
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/cp-calendar-pro

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string

# Field-level encryption (32 bytes, hex-encoded = 64 hex characters)
FIELD_ENCRYPTION_KEY=replace_with_64_char_hex_string

# Google OAuth (Calendar sync)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback

# Gemini API — platform-level fallback; users may supply their own)
GEMINI_API_KEY=your_gemini_api_key

# Code Execution Provider Cascade — tried in order, each optional; a
# provider with no key configured is skipped, not treated as an error.
JDOODLE_CLIENT_ID=your_jdoodle_client_id
JDOODLE_CLIENT_SECRET=your_jdoodle_client_secret
ONECOMPILER_API_KEY=your_onecompiler_api_key
CODEX_RAPIDAPI_KEY=your_rapidapi_key_for_codex

# Ashna AI — OpenAI-compatible API (see AshnaAI docs: Account -> API for the key)
ASHNA_API_KEY=your_ashna_api_key
ASHNA_API_BASE_URL=https://api.ashna.ai/v1/api
ASHNA_CALENDAR_MODEL_ID=your_calendar_agent_or_model_id
ASHNA_NOTES_CODE_MODEL_ID=your_notes_code_agent_or_model_id

# Logging
LOG_LEVEL=info