# Server
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173

# MongoDB
MONGO_URI=mongodb://localhost:27017/cp-calendar-pro

# Redis
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_string
JWT_REFRESH_SECRET=replace_with_a_different_long_random_string

# Field-level encryption (32 bytes, hex-encoded = 64 hex characters)
FIELD_ENCRYPTION_KEY=replace_with_64_char_hex_string

# Google OAuth (Calendar sync)
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_REDIRECT_URI=http://localhost:4000/api/v1/auth/google/callback

# Gemini API (Custom AI Agent — platform-level fallback; users may supply their own)
GEMINI_API_KEY=your_gemini_api_key

# Ashna AI SDK
ASHNA_API_KEY=your_ashna_api_key
ASHNA_API_BASE_URL=https://api.ashna.ai/v1

# Logging
LOG_LEVEL=info