# =============================================
# CP Calendar App — Environment Variables
# =============================================
# Copy this file to .env and fill in your values

# ---- Node ----
NODE_ENV=development
PORT=4000

# ---- Database (PostgreSQL) ----
DATABASE_URL="postgresql://cpuser:cppass@localhost:5432/cp_calendar_dev"

# ---- Redis ----
REDIS_URL="redis://localhost:6379"

# ---- Google OAuth 2.0 ----
# Create credentials at: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret
GOOGLE_CALLBACK_URL=http://localhost:4000/api/v1/auth/google/callback

# ---- Google Calendar API ----
GOOGLE_CALENDAR_API_KEY=your_google_calendar_api_key

# ---- AI Service (for note generation) ----
# Using OpenAI by default — can be swapped for Gemini
OPENAI_API_KEY=sk-your_openai_api_key
AI_MODEL=gpt-4-turbo-preview

# ---- Ashna AI (optional override) ----
ASHNA_AI_API_KEY=
ASHNA_AI_CONTEST_AGENT_URL=
ASHNA_AI_NOTES_AGENT_URL=

# ---- JWT ----
JWT_SECRET=change_this_to_a_long_random_secret_at_least_32_chars
JWT_EXPIRES_IN=7d

# ---- Session ----
SESSION_SECRET=change_this_to_another_long_random_secret_32_chars

# ---- Encryption (AES-256 for OAuth tokens) ----
ENCRYPTION_KEY=change_this_to_exactly_32_character_key

# ---- Frontend ----
FRONTEND_URL=http://localhost:3000

# ---- Logging ----
LOG_LEVEL=info

# ---- Cron ----
SCRAPE_CRON_SCHEDULE="0 */6 * * *"
